{
  "$schema": "https://biomejs.dev/schemas/1.7.3/schema.json",
  "linter": {
    "rules": {
      "correctness": {
        "noUnusedFunctions": "off"
      },
      "javascript": {
        "noUnusedFunctions": "off"
      }
    }
  },
  "files": {
    "ignore": [
      "**/node_modules",
      "**/dist",
      "**/build",
      "**/coverage",
      "**/.git",
      "**/.vscode",
      "**/.idea"
    ]
  }
}